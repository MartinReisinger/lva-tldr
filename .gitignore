# My general gitignore template file for all my git repos.

# macOS
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride

# Editor and IDE state
.idea/
.zed
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
*~

# JetBrains generated project files
/shelf/
/workspace.xml
/httpRequests/
/queries/
/dataSources/
/dataSources.local.xml

# Environment and local secrets
.env
.env.*
!.env.example
.dev.vars
.dev.vars.*
!.dev.vars.example
*.local
include/secrets.h

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Node / pnpm / Nuxt / Vite
node_modules/
.pnpm-store/
.yarn/
.output/
.data/
.nuxt/
.nitro/
.cache/
.vite-inspect/
.remote-assets/
dist/
dist-ssr/
.wrangler/

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# SQLite and local app data
/data/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# PlatformIO / ESP32
.pio/
.pio
.pioenvs/
.piolibdeps/
libdeps/

# Swift / Xcode / iOS
.build/
.swiftpm/
DerivedData/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.xccheckout
*.moved-aside
*.hmap
*.ipa

# C / C++ / CMake / generic build outputs
build/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
compile_commands.json
target

# Coverage and test output
coverage/
.nyc_output/
test-results/
playwright-report/

# Temporary local notes and assistant state
.ai/
.aiignore
.aiassistant/
.claude/
.junie/
CLAUDE.md
AGENTS.md
NOTES.md
internal_docs/
.agents/
